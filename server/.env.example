# ── Required ─────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=replace_me_with_64_hex_chars

# Your login password. Bcrypt-hashed and stored in the DB on first boot.
# You can remove this var after the first successful start.
# To rotate: set a new value and redeploy — it'll overwrite the stored hash.
PASSWORD=change-me-before-deploying

# ── Optional ─────────────────────────────────────────────────
PORT=8080
NODE_ENV=production
# DB_PATH=/data/daily.db   # default: ./data/daily.db inside the container volume
# CORS_ORIGIN=https://daily.yourdomain.com
